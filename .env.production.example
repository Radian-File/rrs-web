# PostgreSQL: internal Docker network only; never publish port 5432.
POSTGRES_DB=rrs
POSTGRES_USER=rrs
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL="postgresql://rrs:replace-with-a-long-random-password@db:5432/rrs?schema=public"

# Public application URL. Start with http://SERVER_IP, then change to https://your-domain after TLS is active.
NEXT_PUBLIC_APP_URL="http://SERVER_IP"
AUTH_SECRET="replace-with-a-random-value-of-at-least-32-characters"
OWNER_EMAIL="owner@example.com"
OWNER_PASSWORD="replace-with-a-strong-owner-password"
OWNER_WHATSAPP_NUMBER="6280000000000"

# Local persistent Docker volume. Back up rrs_uploads together with PostgreSQL.
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# Keep console until an approved email provider is configured.
EMAIL_DRIVER=console
EMAIL_FROM="RRS Studio <noreply@example.com>"

# Keep Sandbox until Midtrans production keys and webhook verification are approved.
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION=false
