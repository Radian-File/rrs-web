# Database (local Docker Compose default)
DATABASE_URL="postgresql://rrs:rrs@127.0.0.1:5434/rrs?schema=public"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="replace-with-at-least-32-random-characters"
OWNER_EMAIL="owner@example.com"
OWNER_PASSWORD="replace-before-seeding"
OWNER_WHATSAPP_NUMBER="6280000000000"

# Storage (local adapter until Phase 16)
STORAGE_DRIVER="local"
LOCAL_UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE_MB="10"

# Midtrans (Sandbox only before Phase 16)
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# Email (console adapter until Phase 16)
EMAIL_DRIVER="console"
EMAIL_FROM="RRS Freelancer <noreply@example.com>"
